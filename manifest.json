{
  "manifest_version": 3,
  "name": "EmoFeedback",
  "version": "1.0",
  "description": "Watch with emotional feedback",
  "action": {
    "default_popup": "html/signup.html"
  },
  "permissions": ["storage", "activeTab", "scripting"],

  "content_scripts": [
    {
      "js": ["js/Content.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_end"
    }
  ]
}